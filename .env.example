# Axiomeer Environment Configuration
# Copy to .env: cp .env.example .env

# ---- Docker (required for docker-compose) ----
DB_PASSWORD=your_secure_password

# ---- Local development (connect to Docker Postgres on localhost:5433) ----
# DATABASE_URL=postgresql://axiomeer:YOUR_PASSWORD@localhost:5433/axiomeer

# ---- Authentication ----
# SECURITY: Set AUTH_ENABLED=true and provide a strong JWT_SECRET_KEY in production
JWT_SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false

# ---- CORS ----
# Comma-separated list of allowed origins. Use "*" only for local dev.
# Example: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=*

# ---- Redis (Docker: auto-set to redis://redis:6379/0) ----
# Set REDIS_PASSWORD to enable Redis auth (strongly recommended in production)
REDIS_PASSWORD=
# If REDIS_PASSWORD is set, update REDIS_URL accordingly:
# REDIS_URL=redis://:your_password@redis:6379/0
REDIS_URL=

# ---- Ollama (for LLM features) ----
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=phi3.5:3.8b

# ---- Semantic Search ----
SEMANTIC_SEARCH_ENABLED=true
SEMANTIC_SEARCH_MODEL=all-MiniLM-L6-v2

# ---- Rate Limits ----
RATE_LIMIT_FREE_TIER_PER_HOUR=100
RATE_LIMIT_STARTER_TIER_PER_HOUR=1000
RATE_LIMIT_PRO_TIER_PER_HOUR=10000
